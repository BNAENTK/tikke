{
  "name": "@tikke/desktop",
  "version": "0.4.1",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "node scripts/prepare-deps.cjs && electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "harness:chat": "tsx harness/scenarios/basic-chat.ts",
    "harness:gift": "tsx harness/scenarios/gift-sound.ts",
    "harness:tts": "tsx harness/scenarios/tts-queue.ts",
    "harness:overlay": "tsx harness/scenarios/overlay-marquee.ts",
    "harness:stress": "tsx harness/runners/queue-stress-runner.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@supabase/supabase-js": "^2.104.1",
    "@tikke/shared": "workspace:*",
    "electron-updater": "^6.1.8",
    "sql.js": "^1.14.1",
    "tiktok-live-connector": "^1.1.9",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "30.5.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.tikke.desktop",
    "productName": "Tikke",
    "npmRebuild": false,
    "copyright": "Copyright © 2024 Tikke",
    "icon": "build/icon.png",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "index.html",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "public/overlays",
        "to": "overlays"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tikke",
      "installerHeaderIcon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "BNAENTK",
      "repo": "tikke"
    }
  }
}
