{
  "name": "@tikke/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist:win": "electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "harness:chat": "tsx harness/scenarios/basic-chat.ts",
    "harness:gift": "tsx harness/scenarios/gift-sound.ts",
    "harness:tts": "tsx harness/scenarios/tts-queue.ts",
    "harness:overlay": "tsx harness/scenarios/overlay-marquee.ts",
    "harness:stress": "tsx harness/runners/queue-stress-runner.ts"
  },
  "dependencies": {
    "@tikke/shared": "workspace:*",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "zustand": "^4.5.2"
  },
  "build": {
    "appId": "com.tikke.desktop",
    "productName": "Tikke",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
